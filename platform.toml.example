# Platform server config — copy to platform.toml at the repo root.
# Everything is optional; CLI flags override these values.
# (platform.toml itself is gitignored — it is machine-local.)

# The live zones-agent's log root (v1 page reads state.json/daily logs here).
# log_root = "C:/Users/trader/Documents/TradingAgentLogs"

# M001 reviews dir holding g7_replay_cache_* (v2 replay page).
# research_reviews = "C:/Users/trader/Documents/GitHub/finance-research-experiments/programs/M001_multi_agent_ensemble/reviews"

# Where the paper loop writes its live stream (default: <log_root>/squad_live).
# live_dir = "C:/Users/trader/Documents/TradingAgentLogs/squad_live"

# Bind address/port. Use 0.0.0.0 to reach the server from another machine —
# set auth_token when you do.
# host = "127.0.0.1"
# port = 8787

# When set AND binding non-localhost, every request must carry the token
# (?token=..., Authorization: Bearer, or the cookie set on first visit).
# auth_token = "change-me"

# DEDICATED squad Telegram bot (v2 paper loop) — separate token + chat
# from the v1 trading bot so match commentary never mixes with trade
# pages. Values here win over the SQUAD_TELEGRAM_BOT_TOKEN /
# SQUAD_TELEGRAM_CHAT_ID env vars (per key). chat_id may be
# comma-separated for multi-chat fan-out. summary_every = closed trades
# between league-table posts (default 10).
# [telegram]
# bot_token = "123456:ABC-..."
# chat_id = "-1001234567890"
# summary_every = 10

# Approved-freshness window (A005): an approved entry is executable
# for this many seconds after the click; afterwards it reads
# "approval_expired" and every gate refuses it. Default 300 (5 min).
# [approvals]
# approved_ttl_seconds = 300

# F023 alerts durability + resource caps.
#   jsonl_sink      -- opt-in (literal true only; default false). When
#                      on, every published bus event ALSO appends to
#                      <config_dir>/alerts_log.jsonl so a crash right
#                      after a safety event keeps the evidence trail.
#                      Sink failures never block delivery. No rotation
#                      policy -- the file is operator-managed.
#   max_sse_streams -- cap on concurrent /api/alerts/stream consumers
#                      (default 8). Past the cap, NEW streams get 429 +
#                      Retry-After; existing streams are never dropped.
# [alerts]
# jsonl_sink = true
# max_sse_streams = 8

# F014 Telegram bridge for the alerts bus. The PRIMARY destination
# reuses the [telegram] bot_token / chat_id above (no new secret) and
# carries all TRADING events (trade_fill, stop_hit, risk_budget_breach,
# approval_submitted). Default disabled.
# [alerts.telegram]
# enabled = true
# [alerts.telegram.per_event]
# trade_fill = true
# approval_submitted = false

# OPS destination (CEO ops-split, 2026-07-24): company/ops alerts go
# to a DIFFERENT bot + chat so ops noise never mixes with trade pages.
# Routing matrix:
#   watchdog_alert                  -> ops destination (falls back to
#                                      primary if this block is
#                                      absent/disabled -- better a
#                                      mis-channeled alert than a
#                                      dropped one)
#   kill_switch_trip, platform_down -> BOTH destinations (safety
#                                      events deserve redundancy)
#   all other trading events        -> primary only
# Fail-closed: fires only when enabled AND bot_token AND chat_id are
# all set. Create the second bot via @BotFather (see
# docs/RUNBOOK_demo_launch.md section 7b.7).
# [alerts.telegram.ops]
# enabled = true
# bot_token = "123456:DEF-..."
# chat_id = "-1009876543210"

# Paper loop replay-cache selection. Both are optional; CLI flags
# (--cache / --aggregator) always win, and if this whole section is
# absent the loop auto-picks the newest g7_replay_cache_g7retry1-*
# under research_reviews (so a fresh G7 second attempt shows up on
# /v2 LIVE without touching config).
#
#   cache      = an explicit cache id (a "g7_replay_cache_*" folder
#                name under research_reviews) or an absolute path.
#   aggregator = shorthand for the g7retry1 arm you want the pitch
#                to observe: "phi41" (verdict-bearing) or "arm4"
#                (companion). Resolves to
#                "g7_replay_cache_g7retry1-<aggregator>".
# [paper_loop]
# aggregator = "phi41"
# cache = "g7_replay_cache_g7retry1-arm4"

# MT5 terminal pin (dual-terminal ops, 2026-07-24 incident). When set,
# EVERY platform-side MT5 session — the /settings/broker connection
# probe and the F018 demo-order executor — initializes against THIS
# terminal install instead of the machine default. That is what lets
# the v1 zones agent keep its own terminal + account untouched while
# the v2 platform talks to a second portable terminal logged into the
# "V2 Platform" account. Unset = historic single-terminal behaviour.
# Setup guide: docs/runbooks/dual-mt5-terminals.md
# [broker]
# terminal_path = "C:/MT5-V2/terminal64.exe"
# portable = true

# Live-market squad paper runtime (scripts/run_squad_live.py).
# CLI flags always win; empty feed = platform default (mt5 on Windows,
# cache elsewhere). Shadow-only — never places broker orders.
# [squad_live]
# feed = "mt5"
# aggregator = "phi41"
# poll_seconds = 45
# symbols = ["EURUSD", "GBPUSD", "USDCAD"]
