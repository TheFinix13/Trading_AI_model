# ── Multi-Pair Trading Agent — Environment Variables ──
# Copy this file to .env and fill in values for live/demo trading.
# Paper mode (`--broker paper`) needs none of these.

# ----- MT5 (live/demo via MetaTrader 5) -----
# Required for --broker mt5 / --broker exness
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# ----- Telegram notifications (optional) -----
TG_BOT_TOKEN=
TG_CHAT_ID=
