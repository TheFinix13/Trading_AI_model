# ── Multi-Pair Trading Agent — Environment Variables ──
# Copy this file to .env and fill in values for live/demo trading.
# Paper mode (`--broker paper`) needs none of these.

# ----- MT5 (live/demo via MetaTrader 5) -----
# Required for --broker mt5 / --broker exness
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# ----- Telegram notifications (optional) -----
TG_BOT_TOKEN=
TG_CHAT_ID=

# ----- Squad Telegram bot (v2 platform, optional) -----
# DEDICATED bot for the Blue Lock squad paper loop — separate token +
# chat so squad commentary never mixes with the v1 trading bot above.
# platform.toml [telegram] overrides these per key when set.
SQUAD_TELEGRAM_BOT_TOKEN=
SQUAD_TELEGRAM_CHAT_ID=
